# Disable JTAG completely - free up GPIO2, GPIO4, GPIO12, GPIO13, GPIO14, GPIO15
CONFIG_ESP_JTAG_MUX_SEL=0
CONFIG_ESP_JTAG_MUX_SEL_EXT_PIN=n
CONFIG_ESP_JTAG_MUX_SEL_PAD=n
CONFIG_ESP_DEBUG_JTAG=n
CONFIG_ESP_JTAG_SEL_ENABLE=n

# Keep WiFi sleep optimization enabled
CONFIG_ESP_WIFI_SLP_IRAM_OPT=y

# Enable 8MB Octal PSRAM
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
